# Caches and virtual environments
.venv/
.pytest_cache/
.ruff_cache/
__pycache__/
*.pyc
.audit-cache/

# IDE settings
.idea/
.vscode/

# Build and packaging
dist/
build/
out/
release/
*.egg-info/
node_modules/
*.tsbuildinfo

# apps/mac/build/ is caught by the blanket build/ rule above, but
# icon-source.svg and icon.icns in there are hand-authored/regenerated
# source assets (electron-builder's build.mac.icon), not generated output --
# track them explicitly.
!apps/mac/build/
apps/mac/build/*
!apps/mac/build/icon-source.svg
!apps/mac/build/icon.icns

# Android (React Native native project)
apps/android/android/.gradle/
apps/android/android/local.properties
apps/android/android/**/.cxx/
apps/android/android/.kotlin/
*.keystore
!debug.keystore

# Core agent runtime config (copy config.example.json to config.json)
config.json

# OS files
.DS_Store

# Agent files and local settings
# .agent/ is ignored except memory/team/ — the one subtree meant to be
# committed and shared with every teammate who clones the repo. The rest
# of that folder holds local, per-machine state and stays out of git.
.agent/*
!.agent/memory/
.agent/memory/*
!.agent/memory/team/
.agents/
.claude/
.gemini/
.direnv-bin/
.worktrees/
docs/**/plans
docs/**/specs
docs/**/enhancements
gemini.md
CLAUDE.md
ANTIGRAVITY.md
opencode.json


# Local execution outputs / configs
e2e_manual_output/
results.sarif
github_conf/
apps/mac/test-results/
apps/mac/playwright-report/

# Generated scan / report artifacts (never commit these)
audit-packs.sarif
oscal.json
coverage.md
coverage.html
*.vsix
